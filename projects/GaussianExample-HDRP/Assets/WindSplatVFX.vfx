  m_Name: 
  m_EditorClassIdentifier: Unity.VisualEffectGraph.Editor::UnityEditor.VFX.Operator.CustomHLSL
  m_UIIgnoredErrors: []
  m_Parent: {fileID: 114350483966674976}
  m_Children: []
  m_UIPosition: {x: 954, y: 1730}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 8926484042661614659}
  - {fileID: 8926484042661614660}
  m_OutputSlots:
  - {fileID: 8926484042661614616}
  m_OperatorName: GetGaussianPosition
  m_HLSLCode: "float3 snoise3D(float3 p) {\r\n    p = frac(p * float3(0.1031, 0.1136,
    0.1377));\r\n    p += dot(p, p.yzx + 19.19);\r\n    return frac((p.xxy + p.yzz)
    * p.zyx) * 2.0 - 1.0;\r\n}\r\n\r\nfloat3 GetGaussianPosition(ByteAddressBuffer
    PositionsBuffer, uint Index)\r\n{\r\n    // 1. Lettura della posizione originale
    (Raw)\r\n    uint address = Index * 12; \r\n    float3 basePos;\r\n    basePos.x
    = asfloat(PositionsBuffer.Load(address));\r\n    basePos.y = asfloat(PositionsBuffer.Load(address
    + 4));\r\n    basePos.z = asfloat(PositionsBuffer.Load(address + 8));\r\n\r\n   
    // 2. Recupero dei parametri globali del vento tramite le macro shader di VFX
    Graph\r\n    // VFX Graph espone automaticamente le propriet\xE0 della Blackboard
    aggiungendo il prefisso \"_\"\r\n    float time = _Time.x; // Tempo globale nativo
    dello shader\r\n    float speed = _WindSpeed;\r\n    float frequency = _WindFrequency;\r\n   
    float intensity = _WindIntensity;\r\n    float3 direction = _WindDirection;\r\n\r\n   
    // 3. Calcolo della turbolenza del vento\r\n    float3 noiseCoords = (basePos
    * frequency) + (direction * time * speed);\r\n    float3 windForce = snoise3D(noiseCoords)
    * intensity;\r\n\r\n    // Attenuazione verso il basso (Y = 0 rimane fermo)\r\n   
    float heightWeight = saturate(basePos.y * 0.5); \r\n    windForce *= heightWeight;\r\n\r\n   
    return basePos + windForce;\r\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunctions:
    selection: GetGaussianPosition
    selectedIndex: 1
